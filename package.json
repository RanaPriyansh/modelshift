{
  "name": "forge-learning-os",
  "version": "0.1.0",
  "private": true,
  "description": "FORGE — a learner-owned system of reviewed learning Worlds, bounded AI support, and proof after help.",
  "license": "MIT",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run && vitest run --config evals/vitest.config.ts",
    "test:watch": "vitest",
    "eval": "tsx evals/run-evals.ts",
    "eval:live": "tsx evals/run-live-evals.ts",
    "test:eval-runner": "vitest run --config evals/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:prod": "PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:?Set PLAYWRIGHT_BASE_URL} playwright test tests/e2e/production.spec.ts"
  },
  "dependencies": {
    "next": "16.2.11",
    "openai": "6.48.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.11",
    "jsdom": "29.1.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
