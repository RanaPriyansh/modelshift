# Server-side only. The complete neutral-fallback journey works without this key.
OPENAI_API_KEY=

# Optional. The governed runtime default is gpt-5.6-sol.
OPENAI_MODEL=gpt-5.6-sol

# External model calls are opt-in and off by default. Keep both false for public
# child/teen access until provider disclosure, consent, and rate controls exist.
# Never set these or either value above through NEXT_PUBLIC_*.
OPENAI_INTERPRETATION_ENABLED=false
OPENAI_FORGE_PLANNER_ENABLED=false

# Emergency switches override the enable flags.
OPENAI_INTERPRETATION_DISABLED=false
OPENAI_FORGE_PLANNER_DISABLED=false
