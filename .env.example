# Server-side only. The complete neutral-fallback journey works without this key.
OPENAI_API_KEY=

# Optional. The governed runtime default is gpt-5.6-sol.
OPENAI_MODEL=gpt-5.6-sol

# External model calls are opt-in and off by default. Keep both false for public
# child/teen access until provider disclosure, consent, and rate controls exist.
# Never set these or either value above through NEXT_PUBLIC_*.
OPENAI_INTERPRETATION_ENABLED=false
OPENAI_FORGE_PLANNER_ENABLED=false

# Optional managed OpenAI adapter for the adult/guardian-facing Lesson Studio.
# Off by default. When false, every provider uses a key supplied for one request.
FORGE_LESSON_STUDIO_OPENAI_ENABLED=false

# Emergency switches override the enable flags.
OPENAI_INTERPRETATION_DISABLED=false
OPENAI_FORGE_PLANNER_DISABLED=false

# Optional adult-only cloud identity stage. All five values must be present;
# otherwise account UI stays in private device mode and does not collect
# credentials. Private-evidence persistence remains disabled pending the ADR-001
# v2 projector. `reviewed` is permitted only after the deployment has an
# enforced Supabase Auth abuse-control configuration and application-level
# throttling. `two_account_isolation_verified` is permitted only after a real,
# disposable configured-project test—not this repository's local fixture.
# Use a Supabase publishable key, never a secret/service-role key.
FORGE_CLOUD_ACCOUNTS_ENABLED=false
FORGE_SUPABASE_URL=
FORGE_SUPABASE_PUBLISHABLE_KEY=
FORGE_CLOUD_AUTH_ABUSE_CONTROLS=
FORGE_CLOUD_AUTH_LIVE_INTEGRATION=
